# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Access control
# The phone number that receives owner_verified auth level.
# Format: E.164, e.g. +12025550100
OWNER_PHONE_NUMBER=+1...

# Discord Bot (Phase 1A.2b)
# Bot token from discord.com/developers/applications > Bot > Reset Token
DISCORD_BOT_TOKEN=your-discord-bot-token
# Your Discord user ID (enable Developer Mode in Discord, right-click yourself, Copy User ID)
DISCORD_OWNER_ID=your-discord-user-id

# Google Calendar MCP (Phase 1A.3)
# Path to your Google OAuth credentials JSON (Desktop App type)
# Get this from Google Cloud Console > APIs & Services > Credentials
GOOGLE_OAUTH_CREDENTIALS_PATH=/path/to/your/gcp-oauth.keys.json

# Persistence (Phase 1A.4)
# Root directory for all persistent data. Defaults to ./data relative to working directory.
KERNOS_DATA_DIR=./data
