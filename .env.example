# === LLM Provider ===
# Choose provider: "anthropic" (default) or "openai-codex" (ChatGPT OAuth)
KERNOS_LLM_PROVIDER=anthropic

# Anthropic (required if KERNOS_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI Codex (required if KERNOS_LLM_PROVIDER=openai-codex)
# Credentials file: .credentials/openai-codex.json
# Or set via env:
# OPENAI_CODEX_ACCESS_TOKEN=...
# OPENAI_CODEX_REFRESH_TOKEN=...
# OPENAI_CODEX_EXPIRES=...
# OPENAI_CODEX_ACCOUNT_ID=...
# OPENAI_CODEX_MODEL=gpt-5.5

# === Discord ===
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_OWNER_ID=your-discord-user-id

# === Cross-Channel Identity ===
# Ties Discord + SMS to one tenant. Format: discord:YOUR_DISCORD_USER_ID
KERNOS_INSTANCE_ID=discord:your-discord-user-id

# === Twilio SMS (optional) ===
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
OWNER_PHONE_NUMBER=+1...
# KERNOS_SMS_POLL_INTERVAL=5

# === Google Calendar MCP ===
# OAuth credentials JSON from Google Cloud Console > APIs & Services > Credentials
GOOGLE_OAUTH_CREDENTIALS_PATH=/path/to/your/gcp-oauth.keys.json

# === Optional Services ===
# BRAVE_API_KEY=...          # Web search (Brave Search API)
# VOYAGE_API_KEY=...         # Enhanced embeddings (Voyage AI) — falls back to hash-only dedup

# === Storage ===
# KERNOS_DATA_DIR=./data     # Root directory for all persistent data

# === Auto-Update ===
# Kernos checks origin/{KERNOS_UPDATE_BRANCH} on startup and pulls + restarts
# if the remote is ahead. Falls back to current code on any failure mode.
#   on (default) — pull + pip install -e . + execv restart when behind
#   off          — skip the update check entirely
# KERNOS_AUTO_UPDATE=on
# KERNOS_UPDATE_BRANCH=main    # override for dogfooding / pre-release branches

# === Workspace Scope ===
# Controls filesystem access for code the agent writes and runs.
#   isolated (default) — subprocess filesystem confined to the active space.
#                        Catches accidental spillover; not a security boundary.
#   unleashed          — subprocess shares the Kernos process's filesystem reach.
# KERNOS_WORKSPACE_SCOPE=isolated

# === Workspace Builder ===
# Which backend writes and runs workspace code.
#   native (default) — Kernos's sandboxed Python subprocess (this batch)
#   aider            — external Python tool (adapter batch pending)
#   claude-code      — external Node binary (adapter batch pending)
#   codex            — external Node binary (adapter batch pending)
# KERNOS_BUILDER=native

# Paths to external builder binaries (only consulted when the matching backend
# is selected; adapter implementations ship in follow-on batches).
# AIDER_BIN=/usr/local/bin/aider
# CLAUDE_CODE_BIN=/usr/local/bin/claude
# CODEX_BIN=/usr/local/bin/codex

# ─────────────────────────────────────────────
# DEBUG / TESTING
# ─────────────────────────────────────────────

# Override compaction threshold for testing (default: 8000 estimated tokens)
# Set low (e.g., 500) to trigger compaction after ~5-6 exchanges
# KERNOS_COMPACTION_THRESHOLD=500

# Hallucination detector mode: "logging" (default, observe-only) or "coaching"
# KERNOS_HALLUCINATION_MODE=logging

# Event trigger poll interval in seconds (default: 60)
# KERNOS_EVENT_POLL_INTERVAL=60

# Max event trigger fires per day per standing trigger (default: 15)
# KERNOS_EVENT_DAILY_CAP=15
